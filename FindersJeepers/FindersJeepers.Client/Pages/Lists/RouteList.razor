@page "/routes"
@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-1 fw-bold">Routes & Stops</MudText>
<MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">Define jeepney routes and their stop sequences.</MudText>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Justify="Justify.SpaceBetween">
    <MudTextField @bind-Value="_search"
                  Placeholder="Search by route code..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Style="max-width:320px;" />
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenAddDialog">
        Add Route
    </MudButton>
</MudStack>

@if (_routes is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (!FilteredRoutes.Any())
{
    <MudAlert Severity="Severity.Info">No routes found.</MudAlert>
}
else
{
    <MudGrid Spacing="3">
        @foreach (var route in FilteredRoutes)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2" Style="border-radius:12px;">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="Color.Tertiary" Size="Size.Large" Variant="Variant.Filled">
                                <MudIcon Icon="@Icons.Material.Filled.AltRoute" />
                            </MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1" Class="fw-bold">@route.RouteCode</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @route.LocationStart → @route.LocationEnd
                            </MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small">
                                @* <MudMenuItem OnClick="() => OpenStopsPanel(route)">Manage Stops</MudMenuItem> *@
                                <MudMenuItem OnClick="() => OpenEditDialog(route)">Edit</MudMenuItem>
                                <MudMenuItem OnClick="() => ConfirmDelete(route)">
                                    <MudText Color="Color.Error">Delete</MudText>
                                </MudMenuItem>
                            </MudMenu>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudDivider />
                    <MudCardContent Class="pt-3">
                        @if (route.Stops.Any())
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2">STOPS (@route.Stops.Count)</MudText>
                            <MudList T="RouteStopResponse" Dense="true" DisablePadding="true">
                                @foreach (var stop in route.Stops.OrderBy(s => s.StopIndex))
                                {
                                    <MudListItem T="RouteStopResponse">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                                                @stop.StopIndex
                                            </MudChip>
                                            <MudText Typo="Typo.body2">@stop.LocationName</MudText>
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary fst-italic">No stops defined yet.</MudText>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@* Add/Edit Route Dialog *@
<MudDialog Visible="_dialogVisible" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Add Route</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.RouteCode" Label="Route Code" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="6">
                <MudSelect Cleara @bind-Value="_form.LocationStartId" Label="Start Location" Variant="Variant.Outlined" Required="true">
                    @foreach (var loc in _availableLocations)
                    {
                        <MudSelectItem Value="@loc.Id">@loc.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="6">
                <MudSelect @bind-Value="_form.LocationEndId" Label="End Location" Variant="Variant.Outlined" Required="true">
                    @foreach (var loc in _availableLocations)
                    {
                        <MudSelectItem Value="@loc.Id">@loc.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDialog">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveRoute">
            Add Route
        </MudButton>
    </DialogActions>
</MudDialog>

@* Manage Stops Dialog *@
