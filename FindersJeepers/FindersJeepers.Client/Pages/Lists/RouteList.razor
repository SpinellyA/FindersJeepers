@code {



    private string _search = string.Empty;
    private bool _dialogVisible = false;
    private bool _stopsDialogVisible = false;
    private bool _isEditing = false;
    private RouteForm _form = new();
    private GetRouteResponse? _selectedRoute;
    private List<EditableStop> _editableStops = new();
    private List<GetRouteResponse>? _routes;
    private List<GetLocationResponse> _availableLocations = new();

    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
    private DialogOptions _stopsDialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true };

    private IEnumerable<GetRouteResponse> FilteredRoutes => _routes?
        .Where(r => string.IsNullOrWhiteSpace(_search) ||
                    r.RouteCode.Contains(_search, StringComparison.OrdinalIgnoreCase))
        ?? Enumerable.Empty<GetRouteResponse>();

    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(500);
        await LoadData();
    }

    private async Task LoadData()
    {
        _routes = await Http.GetFromJsonAsync<List<GetRouteResponse>>("/api/v1/routes");
        _availableLocations = await Http.GetFromJsonAsync<List<GetLocationResponse>>("/api/v1/locations");
    }

    private void OpenAddDialog()
    {
        _form = new RouteForm();
        _isEditing = false;
        _dialogVisible = true;
    }

    private void OpenEditDialog(GetRouteResponse route)
    {
        _form = new RouteForm { Id = route.Id, RouteCode = route.RouteCode };
        _isEditing = true;
        _dialogVisible = true;
    }

    private void OpenStopsPanel(GetRouteResponse route)
    {
        _selectedRoute = route;
        _editableStops = route.Stops
            .Select(s => new EditableStop { StopIndex = s.StopIndex, LocationId = s.LocationId })
            .ToList();
        _stopsDialogVisible = true;
    }

    private void AddStop() =>
        _editableStops.Add(new EditableStop { StopIndex = _editableStops.Count });

    private void CloseDialog() => _dialogVisible = false;

    private async Task SaveRoute()
    {
        var payload = new CreateRouteRequest
            {
                RouteCode = _form.RouteCode,
                StartLocation = _form.LocationStartId,
                EndLocation = _form.LocationEndId
            };

        var response = await Http.PostAsJsonAsync("/api/v1/routes", payload);

        if(response.IsSuccessStatusCode)
        {
            Snackbar.Add("Added Route successfully!");
        } else
        {
            Snackbar.Add("Something went wrong...");
        }
        CloseDialog();
    }

    // private async Task SaveStops()
    // {
    //     Replace with: await RouteService.UpdateStopsAsync(_selectedRoute.Id, _editableStops);
    //     _stopsDialogVisible = false;
    // }

    private async Task ConfirmDelete(GetRouteResponse route)
    {
        // Replace with confirm dialog + await RouteService.DeleteAsync(route.Id);
    }


    public class RouteForm
    {
        public int Id { get; set; }
        public string RouteCode { get; set; } = string.Empty;
        public int LocationStartId { get; set; }
        public int LocationEndId { get; set; }
    }

    public class EditableStop
    {
        public int LocationId { get; set; }
        public int StopIndex { get; set; }
    }

}
