@page "/locations/{Id:int}"
@using MudBlazor

@if (_location is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4 px-0" />

    <MudGrid Spacing="4">

        @* ── Left column: identity card ── *@
        <MudItem xs="12" md="4">
            <MudCard Elevation="2" Style="border-radius:14px;">
                <MudCardContent Class="d-flex flex-column align-items-center text-center pa-6">
                    <MudAvatar Color="Color.Primary" Style="width:80px;height:80px;" Class="mb-3" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Style="font-size:2.2rem;" />
                    </MudAvatar>

                    <MudText Typo="Typo.h5" Class="fw-bold mb-1">@_location.Name</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
                        @(string.IsNullOrWhiteSpace(_location.Description) ? "No description provided." : _location.Description)
                    </MudText>

                    <MudDivider Class="w-100 mb-4" />

                    <MudStack Row="true" Justify="Justify.SpaceEvenly" Class="w-100">
                        <MudStack Spacing="0" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6" Class="fw-bold">@_location.Routes.Count</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Routes</MudText>
                        </MudStack>
                        <MudDivider Vertical="true" FlexItem="true" />
                        <MudStack Spacing="0" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6" Class="fw-bold">@_location.StopOccurrences.Count</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Stop References</MudText>
                        </MudStack>
                    </MudStack>

                    <MudDivider Class="w-100 my-4" />

                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Edit" OnClick="OpenEditDialog">
                        Edit Location
                    </MudButton>
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Right column: routes + stop occurrences ── *@
        <MudItem xs="12" md="8">
            <MudStack Spacing="4">

                @* Routes that pass through this location *@
                <MudCard Elevation="2" Style="border-radius:14px;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Class="fw-bold">Routes Through This Location</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                Routes where this location appears as a start, end, or stop.
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudDivider />
                    <MudCardContent>
                        @if (!_location.Routes.Any())
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">
                                This location is not part of any route yet.
                            </MudAlert>
                        }
                        else
                        {
                            <MudList T="RouteSummaryResponse" Dense="true" DisablePadding="true">
                                @foreach (var route in _location.Routes)
                                {
                                    <MudListItem T="RouteSummaryResponse">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <MudAvatar Color="Color.Tertiary" Size="Size.Small" Variant="Variant.Filled">
                                                    <MudIcon Icon="@Icons.Material.Filled.AltRoute" Size="Size.Small" />
                                                </MudAvatar>
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.body2" Class="fw-bold">@route.RouteCode</MudText>
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                        @route.LocationStart → @route.LocationEnd
                                                    </MudText>
                                                </MudStack>
                                            </MudStack>
                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                                           Size="Size.Small"
                                                           Href="@($"/routes/{route.Id}")" />
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudCardContent>
                </MudCard>

                @* RouteStop occurrences *@
                <MudCard Elevation="2" Style="border-radius:14px;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Class="fw-bold">Stop Occurrences</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                Every route stop entry that references this location and its position.
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudDivider />
                    <MudCardContent>
                        @if (!_location.StopOccurrences.Any())
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">
                                No route stops reference this location yet.
                            </MudAlert>
                        }
                        else
                        {
                            <MudTable Items="_location.StopOccurrences" Dense="true" Hover="true" Elevation="0">
                                <HeaderContent>
                                    <MudTh>Route</MudTh>
                                    <MudTh>Stop Index</MudTh>
                                    <MudTh></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.AltRoute"
                                                     Size="Size.Small" Class="mud-text-secondary" />
                                            <MudText Typo="Typo.body2">@context.RouteCode</MudText>
                                        </MudStack>
                                    </MudTd>
                                    <MudTd>
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                                            Stop #@context.StopIndex
                                        </MudChip>
                                    </MudTd>
                                    <MudTd>
                                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                                       Size="Size.Small"
                                                       Href="@($"/routes/{context.RouteId}")" />
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>

    </MudGrid>
}

@* Edit Dialog *@
<MudDialog @bind-IsVisible="_dialogVisible" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Edit Location</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.Name" Label="Name" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.Description" Label="Description" Variant="Variant.Outlined"
                              Lines="3" AutoGrow="true" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _dialogVisible = false">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveEdit">Save Changes</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int Id { get; set; }

    private GetLocationDetailResponse? _location;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private bool _dialogVisible = false;
    private LocationForm _form = new();

    private DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    protected override async Task OnInitializedAsync()
    {
        // Replace with: _location = await LocationService.GetDetailAsync(Id);
        await Task.Delay(300);

        _location = new GetLocationDetailResponse
        {
            Id = Id,
            Name = "Ayala Center Cebu",
            Description = "Main commercial hub in Cebu City.",
            Routes = new List<RouteSummaryResponse>
            {
                new() { Id = 1, RouteCode = "01A", LocationStart = "Ayala Center Cebu", LocationEnd = "Carbon Market" },
                new() { Id = 3, RouteCode = "03C", LocationStart = "Ayala Center Cebu", LocationEnd = "SM City Cebu" },
            },
            StopOccurrences = new List<RouteStopOccurrenceResponse>
            {
                new() { RouteId = 1, RouteCode = "01A", StopIndex = 0 },
                new() { RouteId = 2, RouteCode = "02B", StopIndex = 2 },
                new() { RouteId = 3, RouteCode = "03C", StopIndex = 0 },
            }
        };

        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Locations", href: "/locations"),
            new(_location.Name, href: null, disabled: true)
        };
    }

    private void OpenEditDialog()
    {
        _form = new LocationForm
        {
            Id = _location!.Id,
            Name = _location.Name,
            Description = _location.Description
        };
        _dialogVisible = true;
    }

    private async Task SaveEdit()
    {
        // Replace with: await LocationService.UpdateAsync(_form);
        _dialogVisible = false;
    }

    public class LocationForm
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
    }
}
