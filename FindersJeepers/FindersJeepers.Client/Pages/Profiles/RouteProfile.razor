@page "/routes/{Id:int}"
@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar

<style>
    .timeline-wrapper {
        transition: opacity 0.25s ease, transform 0.25s ease;
    }

    .timeline-wrapper.fading {
        opacity: 0;
        transform: translateX(10px);
    }
</style>

@if (_route is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    
        var accent      = _showReturn ? Color.Warning  : Color.Primary;
        var accentCss   = _showReturn ? "var(--mud-palette-warning)" : "var(--mud-palette-primary)";
        var originLabel = _showReturn ? _route.LocationEnd   : _route.LocationStart;
        var destLabel   = _showReturn ? _route.LocationStart : _route.LocationEnd;
        var activeStops = _showReturn ? _route.ReturnStops   : _route.Stops;
    

    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4 px-0" />

    <MudGrid Spacing="4">

        <MudItem xs="12" md="4">
            <MudStack Spacing="4">

                <MudCard Elevation="2" Style="border-radius:14px;">
                    <MudCardContent Class="d-flex flex-column align-items-center text-center pa-6">

                        <MudAvatar Color="@accent"
                                   Style="width:80px;height:80px; transition:background-color 0.35s ease;"
                                   Class="mb-3"
                                   Variant="Variant.Filled">
                            <MudIcon Icon="@Icons.Material.Filled.AltRoute" Style="font-size:2.2rem;" />
                        </MudAvatar>

                        <MudText Typo="Typo.h5" Class="fw-bold mb-1">@_route.RouteCode</MudText>

                        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
                            @originLabel → @destLabel
                        </MudText>
                      @*   <MudPaper Elevation="0"
                                  Style="@($"border-radius:999px; padding:4px; background-color:{(_showReturn ? "var(--mud-palette-warning-lighten)" : "var(--mud-palette-primary-lighten)")}; transition:background-color 0.35s ease; border:1px solid {accentCss};")"
                                  Class="d-flex align-items-center">
                            <MudButton Variant="@(!_showReturn ? Variant.Filled : Variant.Text)"
                                       Color="@(!_showReturn ? Color.Primary : Color.Default)"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.ArrowForward"
                                       Style="border-radius:999px; min-width:100px;"
                                       OnClick="() => SetDirection(false)">
                                Forward
                            </MudButton>
                            <MudButton Variant="@(_showReturn ? Variant.Filled : Variant.Text)"
                                       Color="@(_showReturn ? Color.Warning : Color.Default)"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.ArrowBack"
                                       Style="border-radius:999px; min-width:100px;"
                                       OnClick="() => SetDirection(true)">
                                Return
                            </MudButton>
                        </MudPaper> *@

                        <MudDivider Class="w-100 my-4" />

                        <MudStack Row="true" Justify="Justify.SpaceEvenly" Class="w-100">
                            <MudStack Spacing="0" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h6" Class="fw-bold">@_route.Stops.Count</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Fwd Stops</MudText>
                            </MudStack>
                            <MudDivider Vertical="true" FlexItem="true" />
                            <MudStack Spacing="0" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h6" Class="fw-bold">@_route.ReturnStops.Count</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Ret Stops</MudText>
                            </MudStack>
                            <MudDivider Vertical="true" FlexItem="true" />
                            <MudStack Spacing="0" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h6" Class="fw-bold">@_route.AssignedJeepneys.Count</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Jeepneys</MudText>
                            </MudStack>
                        </MudStack>
                    </MudCardContent>
                </MudCard>

                @* Assigned Jeepneys *@
                <MudCard Elevation="2" Style="border-radius:14px;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Class="fw-bold">Assigned Jeepneys</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudDivider />
                    <MudCardContent Class="pa-0">
                        @if (!_route.AssignedJeepneys.Any())
                        {
                            <MudAlert Severity="Severity.Info" Dense="true" Class="ma-3">
                                No jeepneys on this route.
                            </MudAlert>
                        }
                        else
                        {
                            <MudList T="JeepneySummary" Dense="true" DisablePadding="true">
                                @foreach (var j in _route.AssignedJeepneys)
                                {
                                    <MudListItem T="JeepneySummary" Class="px-4 py-2">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <MudAvatar Color="Color.Secondary" Size="Size.Small" Variant="Variant.Filled">
                                                    <MudIcon Icon="@Icons.Material.Filled.DirectionsBus" Size="Size.Small" />
                                                </MudAvatar>
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.body2" Class="fw-bold">@j.PlateNumber</MudText>
                                                </MudStack>
                                            </MudStack>
                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                                           Size="Size.Small"
                                                           Href="@($"/jeepneys/{j.Id}")" />
                                        </MudStack>
                                    </MudListItem>
                                    <MudDivider />
                                }
                            </MudList>
                        }
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>

        @* ── Right column: stop sequence ── *@
        <MudItem xs="12" md="8">
            <MudCard Elevation="2" Style="border-radius:14px;">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Class="fw-bold">Stop Sequence</MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                            Visual timeline of stops along this route.
                        </MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudStack AlignItems="AlignItems.End" Spacing="2">
                            <MudButton Variant="Variant.Outlined"
                                       Color="@accent"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       Style="transition:color 0.3s ease, border-color 0.3s ease;"
                                       OnClick="OpenManageStopsDialog">
                                Manage Stops
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Color="@accent"
                                       Size="Size.Small"
                                       StartIcon="@(_showReturn ? Icons.Material.Filled.ArrowBack : Icons.Material.Filled.ArrowForward)"
                                       EndIcon="@Icons.Material.Filled.SyncAlt"
                                       Style="transition:color 0.3s ease; text-transform:none;"
                                       OnClick="async () => await SetDirection(!_showReturn)">
                                @(_showReturn ? "Return" : "Forward")
                            </MudButton>
                        </MudStack>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudDivider />
                <MudCardContent>

                    <div class="@($"timeline-wrapper{(_isFading ? " fading" : "")}")">

                        @if (!activeStops.Any())
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">
                                No stops defined yet. Use "Manage Stops" to build the route sequence.
                            </MudAlert>
                        }
                        else
                        {
                            <MudTimeline TimelinePosition="TimelinePosition.Start" Class="mt-2">

                                @* Origin *@
                                <MudTimelineItem Color="@accent" Size="Size.Medium" Variant="Variant.Filled">
                                    <ItemDot>
                                        <MudIcon Icon="@Icons.Material.Filled.TripOrigin" Size="Size.Small" />
                                    </ItemDot>
                                    <ItemContent>
                                        <MudStack Spacing="0">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudText Typo="Typo.body1" Class="fw-bold">@originLabel</MudText>
                                                <MudChip T="string" Size="Size.Small" Color="@accent" Variant="Variant.Outlined">Origin</MudChip>
                                            </MudStack>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Start of route</MudText>
                                        </MudStack>
                                    </ItemContent>
                                </MudTimelineItem>

                                @* Middle stops *@
                                @foreach (var stop in activeStops.OrderBy(s => s.StopIndex))
                                {
                                    <MudTimelineItem Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">
                                        <ItemDot>
                                            <MudIcon Icon="@Icons.Material.Filled.FiberManualRecord" Size="Size.Small" />
                                        </ItemDot>
                                        <ItemContent>
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body1" Class="fw-bold">@stop.LocationName</MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Stop #@stop.StopIndex</MudText>
                                            </MudStack>
                                        </ItemContent>
                                    </MudTimelineItem>
                                }

                                @* Destination *@
                                <MudTimelineItem Color="@accent" Size="Size.Medium" Variant="Variant.Filled">
                                    <ItemDot>
                                        <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" />
                                    </ItemDot>
                                    <ItemContent>
                                        <MudStack Spacing="0">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudText Typo="Typo.body1" Class="fw-bold">@destLabel</MudText>
                                                <MudChip T="string" Size="Size.Small" Color="@accent" Variant="Variant.Outlined">Destination</MudChip>
                                            </MudStack>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">End of route</MudText>
                                        </MudStack>
                                    </ItemContent>
                                </MudTimelineItem>

                            </MudTimeline>
                        }
                    </div>

                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    @* ── Manage Stops Dialog ── *@
    <MudDialog Visible="_dialogVisible" Options="_dialogOptions">
        <TitleContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Route" Color="@accent" />
                <MudText Typo="Typo.h6" Class="fw-bold">
                    Build @(_showReturn ? "Return" : "Forward") Route Sequence
                </MudText>
                <MudChip T="string" Size="Size.Small" Color="@accent" Variant="Variant.Outlined">
                    @originLabel → @destLabel
                </MudChip>
            </MudStack>
        </TitleContent>
        <DialogContent>
            <MudGrid Style="min-height:400px;">

                @* ── Left: search & add ── *@
                <MudItem xs="12" md="5">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2 d-block">
                        SEARCH & ADD STOPS
                    </MudText>
                    <MudTextField T="string"
                                  Label="Search locations..."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Value="@_searchQuery"
                                  ValueChanged="HandleSearchChange"
                                  Immediate="true"
                                  Clearable="true" />

                    <MudDivider Class="my-3" />

                    @if (_isSearching)
                    {
                        <MudProgressLinear Indeterminate="true" Color="@accent" />
                    }
                    else if (!string.IsNullOrWhiteSpace(_searchQuery) && !_searchResults.Any())
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary text-center mt-4">
                            No locations found.
                        </MudText>
                    }
                    else
                    {
                        <MudList T="LocationDto" DisablePadding="true">
                            @foreach (var loc in _searchResults)
                            {
                                bool alreadyAdded = _stops.Any(s => s.Id == loc.Id);
                                <MudListItem T="LocationDto"
                                             Disabled="@alreadyAdded"
                                             OnClick="() => AddStop(loc)"
                                             Class="rounded mb-1">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body2" Class="fw-bold">@loc.Name</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@loc.Description</MudText>
                                        </MudStack>
                                        <MudIcon Icon="@(alreadyAdded ? Icons.Material.Filled.Check : Icons.Material.Filled.AddCircleOutline)"
                                                 Size="Size.Small"
                                                 Color="@(alreadyAdded ? Color.Success : accent)" />
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudItem>

                @* ── Divider ── *@
                <MudItem xs="12" md="1" Class="d-flex justify-center">
                    <MudDivider Vertical="true" FlexItem="true" />
                </MudItem>

                @* ── Route builder ── *@
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2 d-block">
                        ROUTE SEQUENCE
                    </MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mb-3 d-block">
                        Stops between <b>@originLabel</b> and <b>@destLabel</b>
                    </MudText>

                    <MudTimeline TimelinePosition="TimelinePosition.Start">

                        @* Fixed origin *@
                        <MudTimelineItem Color="@accent" Size="Size.Small" Variant="Variant.Filled">
                            <ItemContent>
                                <MudPaper Outlined="true" Class="pa-3" Style="@($"border-radius:8px; border-color:{accentCss};")">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudIcon Icon="@Icons.Material.Filled.TripOrigin" Size="Size.Small" Color="@accent" />
                                        <MudStack Spacing="0" Style="flex:1;">
                                            <MudText Typo="Typo.body2" Class="fw-bold">@originLabel</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Origin · cannot be changed</MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            </ItemContent>
                        </MudTimelineItem>

                        @* Dynamic stops *@
                        @if (!_stops.Any())
                        {
                            <MudTimelineItem Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">
                                <ItemContent>
                                    <MudPaper Outlined="true" Class="pa-3" Style="border-radius:8px; border-style:dashed;">
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary text-center fst-italic">
                                            Search and add stops on the left.
                                        </MudText>
                                    </MudPaper>
                                </ItemContent>
                            </MudTimelineItem>
                        }
                        else
                        {
                            @for (int i = 0; i < _stops.Count; i++)
                            {
                                var index = i;
                                var stop = _stops[i];

                                <MudTimelineItem Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">
                                    <ItemContent>
                                        <MudPaper Elevation="1" Class="pa-2" Style="border-radius:8px;">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <MudStack Spacing="0" Style="flex:1;">
                                                    <MudText Typo="Typo.body2" Class="fw-bold">@stop.Name</MudText>
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Stop #@(index + 1)</MudText>
                                                </MudStack>
                                                <MudStack Row="true" Spacing="0">
                                                    <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp"
                                                                   Size="Size.Small"
                                                                   Disabled="@(index == 0)"
                                                                   OnClick="() => MoveStop(index, -1)" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown"
                                                                   Size="Size.Small"
                                                                   Disabled="@(index == _stops.Count - 1)"
                                                                   OnClick="() => MoveStop(index, 1)" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                                                   Size="Size.Small"
                                                                   Color="Color.Error"
                                                                   OnClick="() => RemoveStop(index)" />
                                                </MudStack>
                                            </MudStack>
                                        </MudPaper>
                                    </ItemContent>
                                </MudTimelineItem>
                            }
                        }

                        @* Fixed destination *@
                        <MudTimelineItem Color="@accent" Size="Size.Small" Variant="Variant.Filled">
                            <ItemContent>
                                <MudPaper Outlined="true" Class="pa-3" Style="@($"border-radius:8px; border-color:{accentCss};")">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Color="@accent" />
                                        <MudStack Spacing="0" Style="flex:1;">
                                            <MudText Typo="Typo.body2" Class="fw-bold">@destLabel</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Destination · cannot be changed</MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            </ItemContent>
                        </MudTimelineItem>

                    </MudTimeline>
                </MudItem>

            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100 px-2">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    @_stops.Count intermediate stop(s)
                </MudText>
                <MudStack Row="true" Spacing="2">
                    <MudButton OnClick="() => _dialogVisible = false">Cancel</MudButton>
                    <MudButton Color="@accent" Variant="Variant.Filled" OnClick="SaveStops">
                        Save Sequence
                    </MudButton>
                </MudStack>
            </MudStack>
        </DialogActions>
    </MudDialog>
}

@code {
    [Parameter] public int Id { get; set; }

    private RouteDetail? _route;
    private List<BreadcrumbItem> _breadcrumbs = new();

    // ── Direction toggle ──
    private bool _showReturn = false;
    private bool _isFading   = false;

    private async Task SetDirection(bool returnDirection)
    {
        if (_showReturn == returnDirection) return;

        _isFading = true;
        StateHasChanged();
        await Task.Delay(220); // match CSS transition

        _showReturn = returnDirection;
        _isFading   = false;
        StateHasChanged();
    }

    // ── Dialog ──
    private bool _dialogVisible = false;
    private DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Large,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    private string _searchQuery = string.Empty;
    private List<LocationDto> _searchResults = new();
    private List<LocationDto> _stops = new();
    private bool _isSearching = false;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        _route = await Http.GetFromJsonAsync<RouteDetail>($"/api/v1/routes/{Id}");

        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Routes", href: "/routes"),
            new(_route!.RouteCode, href: null, disabled: true)
        };
    }

    private async Task OpenManageStopsDialog()
    {
        // Load whichever direction is currently active into the builder
        var source = _showReturn ? _route!.ReturnStops : _route!.Stops;
        _stops = source
            .OrderBy(s => s.StopIndex)
            .Select(s => new LocationDto { Id = s.LocationId, Name = s.LocationName })
            .ToList();

        _searchQuery   = string.Empty;
        _searchResults = new();
        _dialogVisible = true;
        await HandleSearchChange(_searchQuery);
    }

    private async Task HandleSearchChange(string query)
    {
        _searchQuery = query;
        _cts?.Cancel();
        _cts = new CancellationTokenSource();

        if (string.IsNullOrWhiteSpace(query))
        {
            _isSearching = true;
            await Task.Delay(300, _cts.Token);
            _searchResults = await Http.GetFromJsonAsync<List<LocationDto>>(
                $"/api/v1/options/locations/",
                _cts.Token) ?? new();
                _isSearching = false;
        }
        else
        try
        {
            _isSearching = true;
            await Task.Delay(300, _cts.Token);
            _searchResults = await Http.GetFromJsonAsync<List<LocationDto>>(
                $"/api/v1/options/locations/search?query={Uri.EscapeDataString(query)}",
                _cts.Token) ?? new();
        }
        catch (TaskCanceledException) { }
        finally { _isSearching = false; }
    }

    private void AddStop(LocationDto loc)
    {
        if (_stops.Any(s => s.Id == loc.Id)) return;
        _stops.Add(loc);
    }

    private void RemoveStop(int index) => _stops.RemoveAt(index);

    private void MoveStop(int index, int direction)
    {
        var item = _stops[index];
        _stops.RemoveAt(index);
        _stops.Insert(index + direction, item);
    }

    private async Task SaveStops()
    {
        var stops = _stops.Select((s, i) => new LocationIndexPair { LocationId = s.Id, Index = i + 1 }).ToList();
        var request = new AddRouteStopRequest
        {
            RouteId      = Id,
            RouteStops   = stops,
            RouteDirection = _showReturn ? RouteDirection.Return : RouteDirection.Forward
        };
        var response = await Http.PutAsJsonAsync($"/api/v1/routes/{Id}/stops", request);

        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Route sequence saved.", Severity.Success);
            _dialogVisible = false;
            _route = await Http.GetFromJsonAsync<RouteDetail>($"/api/v1/routes/{Id}");
        }
        else
        {
            Snackbar.Add("Something went wrong.", Severity.Error);
        }
    }
}
