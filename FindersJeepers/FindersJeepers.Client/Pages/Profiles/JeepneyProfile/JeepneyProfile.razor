@page "/jeepneys/{Id:int}"
@using FindersJeepers.Client.Pages.Profiles.JeepneyProfile.Components
@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar

@if (_vm?.Jeepney is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudBreadcrumbs Items="_vm.Breadcrumbs" Class="mb-4 px-0" />

    <MudGrid Spacing="4">

        <MudItem xs="12" md="4">
            <JeepneyProfileCard Jeepney="_vm.Jeepney"
                                Status="@_vm.JeepneyStatus"
                                StatusColor="_vm.JeepneyStatusColor"
                                StatusIcon="_vm.JeepneyStatusIcon"
                                OnStartTripClick="_vm.OpenStartTripDialog"
                                OnEditClick="() => { }" />
        </MudItem>

        <MudItem xs="12" md="8">
            <MudStack Spacing="4">

                @if (_vm.Jeepney.CurrentTrip is not null)
                {
                    <JeepneyCurrentTripCard Trip="_vm.Jeepney.CurrentTrip" />
                }

                <JeepneyDriversCard AssignedDrivers="_vm.Jeepney.AssignedDrivers"
                                    PreviewCount="JeepneyDetailViewModel.PreviewCount"
                                    OnManageClick="_vm.OpenManageDriversDialog" />

                <JeepneyPastTripsCard Trips="_vm.Jeepney.PastTrips" />

            </MudStack>
        </MudItem>

    </MudGrid>

    <JeepneyStartTripDialog Visible="_vm.StartTripVisible"
                            Drivers="_vm.StartTripDrivers"
                            SelectedDriverId="_vm.StartTripSelectedDriverId"
                            SelectedDriverIdChanged="id => _vm.StartTripSelectedDriverId = id"
                            Direction="_vm.StartTripDirection"
                            DirectionChanged="dir => _vm.StartTripDirection = dir"
                            OnCancel="_vm.CloseStartTripDialog"
                            OnConfirm="async () => await _vm.ConfirmStartTripAsync()" />

    <JeepneyManageDriversDialog Visible="_vm.ManageDriversVisible"
                                AssignedDrivers="_vm.Jeepney.AssignedDrivers"
                                OnClose="_vm.CloseManageDriversDialog"
                                OnAssignClick="async () => await _vm.OpenAssignDriversDialogAsync()"
                                OnRemoveDriver="async d => await _vm.ConfirmRemoveDriverAsync(d)" />

    <JeepneyAssignDriversDialog Visible="_vm.AssignDriversVisible"
                                AvailableDrivers="_vm.AvailableDrivers"
                                SelectedDriverIds="_vm.SelectedDriverIds"
                                OnToggleDriver="id => _vm.ToggleDriver(id)"
                                OnCancel="_vm.CloseAssignDriversDialog"
                                OnConfirm="async () => await _vm.ConfirmAssignDriversAsync()" />
}

@code {
    [Parameter] public int Id { get; set; }

    private JeepneyDetailViewModel? _vm;

    protected override async Task OnInitializedAsync()
    {
        _vm = new JeepneyDetailViewModel(Http, Snackbar);
        await _vm.InitializeAsync(Id);
    }
}