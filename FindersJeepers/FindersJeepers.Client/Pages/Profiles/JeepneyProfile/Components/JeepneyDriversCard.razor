@using MudBlazor

<MudCard Elevation="2" Style="border-radius:14px;">
    <MudCardHeader>
        <CardHeaderContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudText Typo="Typo.h6" Class="fw-bold">Drivers</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                    @(AssignedDrivers?.Count ?? 0)
                </MudChip>
            </MudStack>
        </CardHeaderContent>
        <CardHeaderActions>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.PeopleAlt"
                       OnClick="OnManageClick">
                Manage
            </MudButton>
        </CardHeaderActions>
    </MudCardHeader>
    <MudDivider />
    <MudCardContent Class="pa-0">
        @if (AssignedDrivers is null || !AssignedDrivers.Any())
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="ma-3">
                No drivers assigned to this jeepney.
            </MudAlert>
        }
        else
        {
            <MudList T="JeepneyDriverDto" DisablePadding="true">
                @foreach (var driver in AssignedDrivers.Take(PreviewCount))
                {
                    <MudListItem T="JeepneyDriverDto" Class="px-4 py-2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudAvatar Color="Color.Primary" Size="Size.Small" Variant="Variant.Filled">
                                @driver.FirstName.First()
                            </MudAvatar>
                            <MudStack Spacing="0" Style="flex:1;">
                                <MudText Typo="Typo.body2" Class="fw-bold">@driver.FirstName @driver.LastName</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    Assigned @driver.AssignedAt.ToString("MMM dd, yyyy")
                                </MudText>
                            </MudStack>
                            <MudButton Variant="Variant.Text" Color="Color.Primary"
                                       Size="Size.Small" Href="@($"/drivers/{driver.Id}")">
                                View
                            </MudButton>
                        </MudStack>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>

            @if (AssignedDrivers.Count > PreviewCount)
            {
                <MudButton FullWidth="true" Variant="Variant.Text" Color="Color.Primary"
                           Class="py-2" EndIcon="@Icons.Material.Filled.ExpandMore"
                           OnClick="OnManageClick">
                    View all @AssignedDrivers.Count drivers
                </MudButton>
            }
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public List<JeepneyDriverDto>? AssignedDrivers { get; set; }
    [Parameter] public int PreviewCount { get; set; } = 3;
    [Parameter] public EventCallback OnManageClick { get; set; }
}