@page "/jeepneys/{Id:int}"
@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar

@if (_jeepney is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4 px-0" />

    <MudGrid Spacing="4">

        @* ── Left column: identity card ── *@
        <MudItem xs="12" md="4">
            <MudCard Elevation="2" Style="border-radius:14px;">
                <MudCardContent Class="d-flex flex-column align-items-center text-center pa-6">
                    <MudAvatar Color="Color.Secondary" Style="width:80px;height:80px;" Class="mb-3" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.DirectionsBus" Style="font-size:2.2rem;" />
                    </MudAvatar>
                    <MudText Typo="Typo.h5" Class="fw-bold">@_jeepney.PlateNumber</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-1">Body #@_jeepney.BodyNumber</MudText>
                    <MudChip T="string" Color="@GetStatusColor(_jeepney.CurrentStatus)" Variant="Variant.Filled" Size="Size.Small" Class="mb-4">
                        @_jeepney.CurrentStatus
                    </MudChip>

                    <MudDivider Class="w-100 mb-4" />

                    <MudStack Spacing="2" Class="w-100 text-start">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.AirlineSeatReclineNormal" Size="Size.Small" Class="mud-text-secondary" />
                            <MudText Typo="Typo.body2">Capacity: @_jeepney.Capacity</MudText>
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Route" Size="Size.Small" Class="mud-text-secondary" />
                            <MudText Typo="Typo.body2">Route: @_jeepney.RouteCode</MudText>
                        </MudStack>
                    </MudStack>

                    <MudDivider Class="w-100 my-4" />

                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Edit" OnClick="OpenEditDialog">
                        Edit
                    </MudButton>
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Right column ── *@
        <MudItem xs="12" md="8">
            <MudStack Spacing="4">

                @* Drivers Card *@
                <MudCard Elevation="2" Style="border-radius:14px;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudText Typo="Typo.h6" Class="fw-bold">Drivers</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                                    @(_jeepney.AssignedDrivers?.Count ?? 0)
                                </MudChip>
                            </MudStack>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.PeopleAlt"
                                       OnClick="OpenManageDriversDialog">
                                Manage
                            </MudButton>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudDivider />
                    <MudCardContent Class="pa-0">
                        @if (_jeepney.AssignedDrivers is null || !_jeepney.AssignedDrivers.Any())
                        {
                            <MudAlert Severity="Severity.Info" Dense="true" Class="ma-3">
                                No drivers assigned to this jeepney.
                            </MudAlert>
                        }
                        else
                        {
                            <MudList T="JeepneyDriverDto" DisablePadding="true">
                                @foreach (var driver in _jeepney.AssignedDrivers.Take(_previewCount))
                                {
                                    <MudListItem T="JeepneyDriverDto" Class="px-4 py-2">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                            <MudAvatar Color="Color.Primary" Size="Size.Small" Variant="Variant.Filled">
                                                @driver.FirstName.First()
                                            </MudAvatar>
                                            <MudStack Spacing="0" Style="flex:1;">
                                                <MudText Typo="Typo.body2" Class="fw-bold">@driver.FirstName @driver.LastName</MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                    Assigned @driver.AssignedAt.ToString("MMM dd, yyyy")
                                                </MudText>
                                            </MudStack>
                                            <MudButton Variant="Variant.Text" Color="Color.Primary"
                                                       Size="Size.Small" Href="@($"/drivers/{driver.Id}")">
                                                View
                                            </MudButton>
                                        </MudStack>
                                    </MudListItem>
                                    <MudDivider />
                                }
                            </MudList>

                            @if (_jeepney.AssignedDrivers.Count > _previewCount)
                            {
                                <MudButton FullWidth="true"
                                           Variant="Variant.Text"
                                           Color="Color.Primary"
                                           Class="py-2"
                                           EndIcon="@Icons.Material.Filled.ExpandMore"
                                           OnClick="OpenManageDriversDialog">
                                    View all @_jeepney.AssignedDrivers.Count drivers
                                </MudButton>
                            }
                        }
                    </MudCardContent>
                </MudCard>

                @* Current Trip *@
                <MudCard Elevation="2" Style="border-radius:14px;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Class="fw-bold">Current Trip</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudDivider />
                    <MudCardContent>
                        @if (_jeepney.CurrentTrip is null)
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">No active trip at the moment.</MudAlert>
                        }
                        else
                        {
                            var t = _jeepney.CurrentTrip;
                            <MudStack Spacing="2">
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">TRIP ID</MudText>
                                        <MudText Typo="Typo.body1" Class="fw-bold">#@t.Id</MudText>
                                    </MudStack>
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">STATUS</MudText>
                                        <MudChip T="string" Color="@GetStatusColor(t.Status)" Variant="Variant.Filled" Size="Size.Small">@t.Status</MudChip>
                                    </MudStack>
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">DEPARTED</MudText>
                                        <MudText Typo="Typo.body2">@(t.DepartureTime?.ToString("hh:mm tt") ?? "—")</MudText>
                                    </MudStack>
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">LOGS</MudText>
                                        <MudText Typo="Typo.body2">@t.LogCount</MudText>
                                    </MudStack>
                                </MudStack>
                                <MudButton Variant="Variant.Text" Color="Color.Primary"
                                           Href="@($"/trips/{t.Id}")" StartIcon="@Icons.Material.Filled.OpenInNew">
                                    View Full Trip
                                </MudButton>
                            </MudStack>
                        }
                    </MudCardContent>
                </MudCard>

                @* Past Trips *@
                <MudCard Elevation="2" Style="border-radius:14px;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Class="fw-bold">Past Trips</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudDivider />
                    <MudCardContent>
                        @if (!_jeepney.PastTrips.Any())
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">No past trips recorded.</MudAlert>
                        }
                        else
                        {
                            <MudTable Items="_jeepney.PastTrips" Dense="true" Hover="true" Elevation="0">
                                <HeaderContent>
                                    <MudTh>Trip ID</MudTh>
                                    <MudTh>Route</MudTh>
                                    <MudTh>Departed</MudTh>
                                    <MudTh>Arrived</MudTh>
                                    <MudTh>Logs</MudTh>
                                    <MudTh></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>#@context.Id</MudTd>
                                    <MudTd>@context.RouteCode</MudTd>
                                    <MudTd>@(context.DepartureTime?.ToString("MMM dd, hh:mm tt") ?? "—")</MudTd>
                                    <MudTd>@(context.ArrivalTime?.ToString("MMM dd, hh:mm tt") ?? "—")</MudTd>
                                    <MudTd>@context.LogCount</MudTd>
                                    <MudTd>
                                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small"
                                                       Href="@($"/trips/{context.Id}")" />
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>
    </MudGrid>
}

@* ── Manage Drivers Dialog ── *@
<MudDialog Visible="_manageDriversVisible" Options="_manageDialogOptions">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
            <MudText Typo="Typo.h6" Class="fw-bold">Manage Drivers</MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.PersonAdd"
                       OnClick="OpenAssignDialog">
                Assign Drivers
            </MudButton>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_jeepney?.AssignedDrivers is null || !_jeepney.AssignedDrivers.Any())
        {
            <MudAlert Severity="Severity.Info" Dense="true">No drivers assigned yet.</MudAlert>
        }
        else
        {
            <MudList T="JeepneyDriverDto" DisablePadding="true">
                @foreach (var driver in _jeepney.AssignedDrivers)
                {
                    <MudListItem T="JeepneyDriverDto" Class="px-0">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudAvatar Color="Color.Primary" Size="Size.Medium" Variant="Variant.Filled">
                                @driver.FirstName.First()
                            </MudAvatar>
                            <MudStack Spacing="0" Style="flex:1;">
                                <MudText Typo="Typo.body1" Class="fw-bold">@driver.FirstName @driver.LastName</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    Assigned @driver.AssignedAt.ToString("MMM dd, yyyy")
                                </MudText>
                            </MudStack>
                            <MudButton Variant="Variant.Text" Color="Color.Primary"
                                       Size="Size.Small" Href="@($"/drivers/{driver.Id}")">
                                View
                            </MudButton>
                            <MudIconButton Icon="@Icons.Material.Filled.PersonRemove"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="() => ConfirmRemoveDriver(driver)" />
                        </MudStack>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _manageDriversVisible = false">Close</MudButton>
    </DialogActions>
</MudDialog>

@* ── Assign Drivers Dialog ── *@
<MudDialog Visible="_assignDriversVisible" Options="_assignDialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6" Class="fw-bold">Assign Drivers</MudText>
    </TitleContent>
    <DialogContent>
        @if (_availableDrivers is null)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (!_availableDrivers.Any())
        {
            <MudAlert Severity="Severity.Info" Dense="true">No drivers available to assign.</MudAlert>
        }
        else
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
                Select drivers to add to this jeepney.
            </MudText>
            <MudStack Spacing="2">
                @foreach (var driver in _availableDrivers)
                {
                    bool isSelected = _selectedDriverIds.Contains(driver.Id);
                    <MudPaper Outlined="true"
                              Style="@($"border-radius:8px; cursor:pointer; border-color:{(isSelected ? "var(--mud-palette-primary)" : "var(--mud-palette-lines-default)")}")"
                              Class="pa-3"
                              @onclick="() => ToggleDriver(driver.Id)">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudCheckBox Value="isSelected" Color="Color.Primary" ReadOnly="true" />
                            <MudAvatar Color="Color.Primary" Size="Size.Medium" Variant="Variant.Filled">
                                @driver.FirstName.First()
                            </MudAvatar>
                            <MudText Typo="Typo.body2" Class="fw-bold" Style="flex:1;">@driver.FirstName</MudText>
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100 px-2">
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                @_selectedDriverIds.Count driver(s) selected
            </MudText>
            <MudStack Row="true" Spacing="2">
                <MudButton OnClick="() => _assignDriversVisible = false">Cancel</MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="@(!_selectedDriverIds.Any())"
                           OnClick="ConfirmAssignDrivers">
                    Assign
                </MudButton>
            </MudStack>
        </MudStack>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int Id { get; set; }

    private JeepneyDetail? _jeepney;
    private List<BreadcrumbItem> _breadcrumbs = new();

    private bool _manageDriversVisible = false;
    private bool _assignDriversVisible = false;
    private List<DriverOption>? _availableDrivers;
    private HashSet<int> _selectedDriverIds = new();

    private const int _previewCount = 3;

    private DialogOptions _manageDialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    private DialogOptions _assignDialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    protected override async Task OnInitializedAsync()
    {
        _jeepney = await Http.GetFromJsonAsync<JeepneyDetail>($"/api/v1/jeepneys/{Id}");

        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Jeepneys", href: "/jeepneys"),
            new(_jeepney!.PlateNumber, href: null, disabled: true)
        };
    }

    private void OpenManageDriversDialog() => _manageDriversVisible = true;

    private async Task OpenAssignDialog()
    {
        _selectedDriverIds = new();
        _availableDrivers = null;
        _assignDriversVisible = true;

        // Replace with: _availableDrivers = await Http.GetFromJsonAsync<List<DriverOption>>($"/api/options/drivers/available-for-jeep/{Id}");
        await Task.Delay(300);
        _availableDrivers = new List<DriverOption>
        {
            new() { Id = 10, FirstName = "Pedro Reyes" },
            new() { Id = 11, FirstName = "Jose Rizal" },
        };
    }

    private void ToggleDriver(int driverId)
    {
        if (!_selectedDriverIds.Add(driverId))
            _selectedDriverIds.Remove(driverId);
    }

    private async Task ConfirmAssignDrivers()
    {
        // Replace with:
        // await Http.PostAsJsonAsync($"/api/jeepneys/{Id}/drivers", new { DriverIds = _selectedDriverIds.ToList() });
        // _jeepney = await Http.GetFromJsonAsync<GetJeepneyDetailResponse>($"/api/v1/jeepneys/{Id}");
        _assignDriversVisible = false;
        _selectedDriverIds = new();
        Snackbar.Add("Drivers assigned successfully.", Severity.Success);
    }

    private async Task ConfirmRemoveDriver(JeepneyDriverDto driver)
    {
        await Http.DeleteAsync($"/api/v1/jeepneys/{Id}/drivers/{driver.Id}");
        Snackbar.Add($"{driver.FirstName} has been removed.", Severity.Info);
    }

    private void OpenEditDialog() { }

    private Color GetStatusColor(string status) => status switch
    {
        "OnGoing" => Color.Success,
        "Waiting" => Color.Warning,
        "Completed" => Color.Default,
        _ => Color.Default
    };
}
